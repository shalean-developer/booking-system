# =============================================================================
# Copy this file to `.env.local` in the project root and fill in your values.
# Next.js loads `.env.local` automatically (it is gitignored — never commit secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Supabase (Project Settings → API)
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: bypasses RLS for API routes, webhooks, admin scripts, storage uploads
# Never expose as NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# Secures POST /api/create-post and POST /api/create-location-page (Bearer or x-api-key)
# Prefer this; if unset, BLOG_CREATE_POST_SECRET is used for the same APIs
SEO_CONTENT_API_SECRET=
BLOG_CREATE_POST_SECRET=

# -----------------------------------------------------------------------------
# REQUIRED in production — Paystack (or set REQUIRE_PAYSTACK_KEYS=true locally)
# https://dashboard.paystack.com/#/settings/developer
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Set to true to require Paystack keys even when NODE_ENV is not production
REQUIRE_PAYSTACK_KEYS=false

# Optional: override Paystack callback base (booking flow / Edge)
# PAYSTACK_CALLBACK_URL=https://your-domain.com/booking/payment/callback

# -----------------------------------------------------------------------------
# RECOMMENDED — Public site URL (Paystack callbacks, emails, absolute links)
# Local dev example: http://localhost:3001  (this project uses port 3001 in package.json)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=
# NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_APP_URL=
# VERCEL_URL is set automatically on Vercel — you usually do not set it locally

# -----------------------------------------------------------------------------
# RECOMMENDED — Transactional email (Resend)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=
SENDER_EMAIL=
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Customer dashboard — support fallbacks (call / WhatsApp when cleaner has no phone)
# Use E.164, e.g. +27821234567
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_SUPPORT_EMAIL=

# -----------------------------------------------------------------------------
# OPTIONAL — Booking & checkout
# -----------------------------------------------------------------------------
# HMAC for signed confirmation/receipt links (?ct=)
BOOKING_CONFIRMATION_SECRET=

# After deploying `check_date_availability` in Supabase, set true to enforce RPC
BOOKING_ENFORCE_AVAILABILITY_RPC=false

# Pay-later pending bookings API (disabled in production unless explicitly enabled)
ALLOW_PAY_LATER_BOOKINGS=false

# Browser console logs for booking flow debugging
NEXT_PUBLIC_DEBUG_BOOKING_FLOW=false

# -----------------------------------------------------------------------------
# OPTIONAL — Zoho Books (invoices; also used by Edge Functions — set secrets in Supabase Dashboard)
# -----------------------------------------------------------------------------
ZOHO_BOOKS_ORGANIZATION_ID=
ZOHO_ACCESS_TOKEN=
ZOHO_REFRESH_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_HOST=https://accounts.zoho.com
ZOHO_BOOKS_API_HOST=https://www.zohoapis.com
# ZOHO_BOOKS_DEPOSIT_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# OPTIONAL — Google (Maps / Places / reviews widget)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ENABLE_GOOGLE_PLACES=false
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=
# NEXT_PUBLIC_GOOGLE_PLACE_ID=

# Google Business Profile “Share” link for your listing
# NEXT_PUBLIC_GBP_URL=

# -----------------------------------------------------------------------------
# OPTIONAL — WhatsApp / Flaxxa WAPI (lib/notifications/whatsapp.ts)
# -----------------------------------------------------------------------------
ENABLE_WHATSAPP=false
NEXT_PUBLIC_ENABLE_WHATSAPP=false
ENABLE_WHATSAPP_CUSTOMER=false
WAPI_BASE_URL=https://wapi.flaxxa.com
WAPI_API_KEY=
WAPI_SENDER_ID=

# -----------------------------------------------------------------------------
# OPTIONAL — Telegram bot (npm run telegram-bot)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# BOT_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL — Analytics & monitoring
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# OPTIONAL — Email testing / debug routes
# -----------------------------------------------------------------------------
DEBUG_EMAIL_TO=
TEST_EMAIL_TO=

# -----------------------------------------------------------------------------
# Edge Functions / pay-later (lib/payment-edge.ts) — mirror secrets in Supabase Dashboard
# Supabase CLI: supabase secrets set --env-file ./supabase/.env.edge
# -----------------------------------------------------------------------------
