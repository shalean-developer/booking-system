# Copy to `.env.local` in the project root (Next.js does not read this file).
# Supabase: https://supabase.com/dashboard/project/_/settings/api
#   - Project URL → NEXT_PUBLIC_SUPABASE_URL
#   - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role (secret) → SUPABASE_SERVICE_ROLE_KEY — server/API only; never NEXT_PUBLIC_

NEXT_PUBLIC_SUPABASE_URL=https://utfvbtcszzafuoyytlpf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV0ZnZidGNzenphZnVveXl0bHBmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjAyMjQ3MjAsImV4cCI6MjA3NTgwMDcyMH0.-9WTppziWrLd4tWo-QEFaojlIJenTt6wMgIBmEpFwMs

# Optional but required for some admin/storage/server operations:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Business Profile – Maps “Share” link for your listing (not a google.com/search URL)
# NEXT_PUBLIC_GBP_URL=https://www.google.com/maps/place/Your+Business/...

# Telegram bot (optional — run: npm run telegram-bot or node lib/telegramBot.js)
# Get a token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=

# After deploying `check_date_availability` in Supabase, set to true to block checkout when the RPC fails.
# Default: false (uses cart total without surge if RPC is missing or errors).
# BOOKING_ENFORCE_AVAILABILITY_RPC=true

# Paystack — required on the server when NODE_ENV=production (or set REQUIRE_PAYSTACK_KEYS=true).
# For local dev you can omit these if you use guest checkout / dev flows; add both to test real card charges.
# Public: https://dashboard.paystack.com/#/settings/developer — Secret: same page (server-only, never NEXT_PUBLIC_).
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_16df27480acd81aaf20b136ff5d9b53af08fd79e
PAYSTACK_SECRET_KEY=sk_test_3586fceaa64ccb45771cc59f37348512798c5db9

# Set to true to require Paystack keys even in development (stricter local testing).
# REQUIRE_PAYSTACK_KEYS=false

# Booking checkout security (recommended for production)
# HMAC secret for confirmation/receipt links (?ct=). Without it, lookup by ref stays open (legacy).
# BOOKING_CONFIRMATION_SECRET=generate_a_long_random_string

# Pay-later (rewards) API — disabled in production unless explicitly enabled
# ALLOW_PAY_LATER_BOOKINGS=false

# Trace checkout → /booking/confirmation in the browser console ([booking-flow] logs)
# NEXT_PUBLIC_DEBUG_BOOKING_FLOW=true

# --- Public site URL (Paystack callback_url in /api/paystack/initialize; emails) ---
# Local: NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_BASE_URL=https://your-domain.com (Vercel also sets VERCEL_URL; request Host is used as fallback)
# NEXT_PUBLIC_SITE_URL=…
# NEXT_PUBLIC_APP_URL=…

# Optional override for Paystack callback base (booking_id is appended by the Edge Function)
# PAYSTACK_CALLBACK_URL=https://your-domain.com/booking/payment/callback

# Transactional email (Resend) — also used by Next.js lib/email.ts
# RESEND_API_KEY=re_HBw91SYL_HRtdrxnP5V1QFAhW1WG7iiDR
# SENDER_EMAIL=bookings@shalean.com
# ADMIN_EMAIL=admin@shalean.com

# Supabase Edge Functions — copy the same values into Dashboard → Project → Edge Functions → Secrets
# so paystack-webhook / verify-payment can create Zoho invoices and send Resend emails (Edge does not read .env.local).
# CLI:  supabase secrets set --env-file ./supabase/.env.edge   (or set each key interactively)

# Zoho Books — invoices use Contacts API (create/list customer). OAuth scopes must include at least:
# ZohoBooks.invoices.CREATE, ZohoBooks.contacts.READ, ZohoBooks.contacts.CREATE (or ZohoBooks.fullaccess.all).
# Zoho Books — invoices after successful payment (Edge Functions + lib/zoho-books-server.ts)
# ZOHO_BOOKS_ORGANIZATION_ID=847311616
# ZOHO_ACCESS_TOKEN=
# Optional OAuth refresh (recommended for production)
# ZOHO_REFRESH_TOKEN=1000.5de682037b4d92ec6bf9f1c3388c932c.5169666823f3cd32bf8ac13877fb0a05
# ZOHO_CLIENT_ID=1000.KKWRPOED2NI43JA44MLKAPHU8HI47U
# ZOHO_CLIENT_SECRET=0a823a9d5e26def2b540323de3df8df79606ae80e5
# ZOHO_ACCOUNTS_HOST=https://accounts.zoho.com
# ZOHO_BOOKS_API_HOST=https://www.zohoapis.com
