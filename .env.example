# =============================================================================
# Copy to `.env.local` or set in Vercel (Production / Preview / Development).
# Values shown empty are secrets or deployment-specific — fill as needed.
# =============================================================================

# --- Supabase (client + server) ------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never expose to the browser. Required for service role API routes & scripts.
SUPABASE_SERVICE_ROLE_KEY=

# --- Public site URLs ----------------------------------------------------------
# Must include scheme, e.g. https://shalean.co.za
NEXT_PUBLIC_SITE_URL=
# Optional fallbacks used by links, referrals, Edge Functions (see also VERCEL_URL on Vercel).
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_APP_URL=
# Google Business Profile / marketing link (optional)
NEXT_PUBLIC_GBP_URL=

# --- Paystack (checkout + webhooks + transfers) -------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Set true in prod or CI to require Paystack keys (optional in local dev).
REQUIRE_PAYSTACK_KEYS=
# Optional: override Paystack callback (Supabase Edge initialize-payment uses this if set).
PAYSTACK_CALLBACK_URL=
# Webhooks (Paystack Dashboard): use ONE URL for charge events → https://<app>/api/payment/webhook
# Payout transfers → https://<app>/api/webhooks/paystack — do NOT register Supabase Edge for charge.* (duplicate risk).
# After N failures per reference (amount/currency/reference), logs payment_validation_repeated_failure.
# PAYMENT_VALIDATION_FAILURE_ALERT_THRESHOLD=3

# --- Resend (transactional email) ---------------------------------------------
RESEND_API_KEY=
SENDER_EMAIL=
ADMIN_EMAIL=
# Optional: shown in careers templates / routing
CAREERS_PUBLIC_EMAIL=
CAREERS_ADMIN_EMAIL=
# Optional: server-only support inbox if NEXT_PUBLIC_SUPPORT_EMAIL unset
SUPPORT_EMAIL=
# Cron / ops alerts (lib/cron-alert.ts)
ALERT_EMAIL=

# --- Dev-only debug APIs (lib/debug-api-auth.ts) ------------------------------
# Protects GET /api/debug-email, /api/test-email, /api/services/debug when NODE_ENV !== production.
# Use a long random string. Admins (customers.role = admin) may call without this.
# DEBUG_API_SECRET=

# --- Zoho Books (invoices, PDF, sync) -----------------------------------------
ZOHO_BOOKS_ORGANIZATION_ID=
ZOHO_ACCESS_TOKEN=
# OAuth (recommended for production):
# ZOHO_REFRESH_TOKEN=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_ACCOUNTS_HOST=https://accounts.zoho.com
# ZOHO_BOOKS_API_HOST=https://www.zohoapis.com
# ZOHO_BOOKS_WEB_HOST=
# Optional custom fields / accounts (see lib/zoho-books-server.ts)
# ZOHO_BOOKS_CUSTOM_FIELD_BOOKING_ID=
# ZOHO_BOOKS_DEPOSIT_ACCOUNT_ID=

# --- Cron (external schedulers: append ?secret=...) ---------------------------
CRON_SECRET=
CRON_INVOKE_URL=https://shalean.co.za
CRON_EDGE_KEY=

# --- Cleaner wallet / Paystack payouts ----------------------------------------
# GET /api/cron/payouts?secret=CRON_SECRET | POST /api/webhooks/paystack
# PAYSTACK_MIN_PAYOUT_CENTS=50000
# MIN_PAYOUT_CENTS=50000
# PAYOUT_HOLD_HOURS=24
# PAYSTACK_PAYOUT_CURRENCY=ZAR
# PAYSTACK_RECIPIENT_TYPE=basa
# PAYOUT_MAX_RETRIES=3
# PAYOUT_RETRY_BASE_DELAY_SECONDS=3600
# PAYOUT_STALE_PROCESSING_HOURS=72

# --- OpenAI / SEO / blog (cron + scripts) -------------------------------------
OPENAI_API_KEY=
SEO_CONTENT_API_SECRET=
BLOG_CREATE_POST_SECRET=
# Scripts: generate-topics, generate-blog-posts, generate-location-pages, update-old-posts
TOPICS_COUNT=10
# BLOG_POSTS_API_URL=
# CONTENT_API_URL=
# LOCATION_PAGES_API_URL=
# ADMIN_BLOG_API_URL=http://localhost:3001/api/admin/blog
# BLOG_UPDATE_API_URL=http://localhost:3001/api/admin/blog/update
# REVALIDATE_BASE_URL=http://localhost:3001
# UPDATE_POSTS_LIMIT=5
# UPDATE_POSTS_STALE_DAYS=30
# UPDATE_INCLUDE_DRAFTS=false

# --- Google (Search Console API, Places, widgets) -----------------------------
# JSON service account or credentials string for /api/seo/search-console
GSC_CREDENTIALS=
GSC_SITE_URL=
NEXT_PUBLIC_ENABLE_GOOGLE_PLACES=false
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_PLACE_ID=

# --- Analytics / error tracking -----------------------------------------------
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SENTRY_DSN=

# --- Public support / contact (marketing + UI) ---------------------------------
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_SUPPORT_CALL_DISPLAY=
NEXT_PUBLIC_SUPPORT_CALL_TEL=
NEXT_PUBLIC_SUPPORT_WHATSAPP_E164=
# Optional legacy alias for WhatsApp digits (used if NEXT_PUBLIC_SUPPORT_WHATSAPP_E164 is unset)
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_SUPPORT_WHATSAPP_DISPLAY=

# --- WhatsApp / WAPI (lib/notifications/whatsapp.ts) ---------------------------
ENABLE_WHATSAPP=
NEXT_PUBLIC_ENABLE_WHATSAPP=
ENABLE_WHATSAPP_CUSTOMER=
WAPI_BASE_URL=https://wapi.flaxxa.com
WAPI_API_KEY=
WAPI_SENDER_ID=

# --- Telegram (lib/telegramBot.js) -------------------------------------------
TELEGRAM_BOT_TOKEN=
# Alias used by some deployments
BOT_TOKEN=

# --- Booking / security --------------------------------------------------------
BOOKING_CONFIRMATION_SECRET=
BOOKING_ENFORCE_AVAILABILITY_RPC=false
ALLOW_PAY_LATER_BOOKINGS=
NEXT_PUBLIC_DEBUG_BOOKING_FLOW=false

# --- Admin dashboard -----------------------------------------------------------
NEXT_PUBLIC_ADMIN_MONTHLY_REVENUE_GOAL_CENTS=
AI_AUTO_OPTIMIZATION=false

# --- Development / tooling ------------------------------------------------------
# Webpack bundle analyzer: npm run build with ANALYZE=true
ANALYZE=false
# GET /api/test-email — default recipient if no ?to=
TEST_EMAIL_TO=

# =============================================================================
# Platform / read-only (set automatically on Vercel — do not add to .env.local)
# =============================================================================
# VERCEL_URL — public deployment host, used by lib/public-base-url.ts

# =============================================================================
# Supabase Edge Functions (Deno) — secrets in Supabase Dashboard or CLI
# =============================================================================
# SUPABASE_URL — same project URL as NEXT_PUBLIC_SUPABASE_URL (often injected by Supabase)
# SUPABASE_SERVICE_ROLE_KEY — same as server key above
# Same Paystack, Resend, Zoho, CRON_* keys as above where applicable.
