# Copy into `.env.local` or Vercel (all environments: Production, Preview, Development).
# NEXT_PUBLIC_SITE_URL must include the scheme, e.g. https://shalean.co.za (not bare domain).
# For the same paid confirmation + PDF invoice behaviour in test/preview as in production,
# use the same Zoho Books values everywhere (or a dedicated Zoho org for staging).

# Zoho Books — required for automatic tax invoices + PDF on confirmation email
ZOHO_BOOKS_ORGANIZATION_ID=
# Use either a static access token:
ZOHO_ACCESS_TOKEN=
# Or OAuth refresh (recommended for production):
# ZOHO_REFRESH_TOKEN=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# Match your Zoho data center (EU example):
# ZOHO_ACCOUNTS_HOST=https://accounts.zoho.eu
# ZOHO_BOOKS_API_HOST=https://www.zohoapis.eu
