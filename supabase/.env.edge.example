# Secrets for Supabase Edge Functions (Dashboard → Edge Functions → Secrets),
# or: supabase secrets set --env-file ./supabase/.env.edge
#
# Edge runtime provides SUPABASE_URL automatically in hosted Supabase; for local
# testing you may set it explicitly to your project URL.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PAYSTACK_SECRET_KEY=

RESEND_API_KEY=
SENDER_EMAIL=
ADMIN_EMAIL=

NEXT_PUBLIC_APP_URL=
PAYSTACK_CALLBACK_URL=

ZOHO_BOOKS_ORGANIZATION_ID=
ZOHO_ACCESS_TOKEN=
ZOHO_REFRESH_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_HOST=https://accounts.zoho.com
ZOHO_BOOKS_API_HOST=https://www.zohoapis.com
